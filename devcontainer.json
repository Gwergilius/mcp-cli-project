{
  "postCreateCommand": [
    "pip install ruff", 
    "npm install -g @anthropic-ai/claude-code"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  }
}