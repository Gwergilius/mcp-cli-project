{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainerBase.schema.json",
  "postCreateCommand": {
    "installRuff": "pip install ruff",
    "installClaudeCode": "npm install -g @anthropic-ai/claude-code"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "anthropic-ai.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  }
}